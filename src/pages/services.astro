<!-- ===== HOW TO CHOOSE ===== -->
<section class="bg-gray">
  <div class="container">
    <div class="section-header centered">
      <span class="section-label">Decision Guide</span>
      <h2 class="section-title">Which Service Is Right for You?</h2>
    </div>
    <div class="grid grid-3">
      <div class="card fade-up">
        <div class="card-body">
          <h4 style="color:var(--navy); margin-bottom:1rem;">Quick Assessment</h4>
          <p style="font-size:0.9rem; margin-bottom:1rem;"><strong>Tier 1</strong> → Identify gaps → Plan improvements independently</p>
          <p style="font-size:0.875rem; margin:0; color:var(--text-light);">Best for boards with basic compliance understanding, planning to act internally.</p>
        </div>
      </div>
      <div class="card fade-up">
        <div class="card-body">
          <h4 style="color:var(--navy); margin-bottom:1rem;">Complete Turnaround</h4>
          <p style="font-size:0.9rem; margin-bottom:1rem;"><strong>Tier 2</strong> → Audit + strategy → Implementation with clear roadmap</p>
          <p style="font-size:0.875rem; margin:0; color:var(--text-light);">Best for boards ready for real change, wanting a concrete improvement roadmap.</p>
        </div>
      </div>
      <div class="card fade-up">
        <div class="card-body">
          <h4 style="color:var(--navy); margin-bottom:1rem;">Full Partnership</h4>
          <p style="font-size:0.9rem; margin-bottom:1rem;"><strong>Tier 3</strong> → Full transformation → 12+ months hands-on support</p>
          <p style="font-size:0.875rem; margin:0; color:var(--text-light);">Best for boards committed to excellence, wanting end-to-end implementation support.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="cta-section">
  <div class="container">
    <h2>Not Sure Where to Start?</h2>
    <p>Book a free 30-minute call and I'll recommend the right service for your board's specific situation.</p>
    <div class="btn-group" style="justify-content:center;">
      <a href="/contact" class="btn btn-primary btn-lg">Book Free 30-Minute Consultation</a>
    </div>
    <div class="cta-contact-row">
      <span class="cta-contact-item">📧 jennifercly@gmail.com</span>
      <span class="cta-contact-item">📞 +65 8577 6630</span>
    </div>
  </div>
</section>

</Layout>
